{
  "mcpServers": {
    "jgs-sysmlv2": {
      "command": "python",
      "args": ["-m", "jgs_sysmlv2_api_mcp"],
      "env": {
        "SYSMLV2_BASE_URL": "https://your-sysmlv2-endpoint.example.com",
        "SYSMLV2_TOKEN": "YOUR_BEARER_TOKEN_HERE",
        "SYSMLV2_PROJECT": "YOUR_PROJECT_UUID_HERE"
      }
    }
  }
}
